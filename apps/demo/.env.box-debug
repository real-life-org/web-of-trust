# Festival-Box-Dry-Run — Offline-Pi-Backend (box.web-of-trust.de) + D2-Observability.
#
# Pendant zu .env.staging-debug, aber gegen die Raspberry-Pi-Offline-Box
# (deploy/offline-pi/): Relay/Profiles/Vault laufen auf dem Pi, TLS über das
# echte Wildcard-Cert, DNS nur im wot-demo-WLAN (bzw. auf Rechnern, die den
# Pi-dnsmasq nutzen). NUR für side-loaded Debug-APKs / manuelle Test-Builds —
# NIEMALS durch die Release-/OTA-Pipeline (Deploy-Path-Guard siehe
# docs/testing/spur-b-native-dryrun.md).
#
# Aktivierung ausschliesslich explizit via:  vite build --mode box-debug

VITE_BASE_PATH=/
VITE_RELAY_URL=wss://relay.box.web-of-trust.de
VITE_PROFILE_SERVICE_URL=https://profiles.box.web-of-trust.de
VITE_VAULT_URL=https://vault.box.web-of-trust.de
VITE_WOT_DEBUG_OBSERVABILITY=1

# Stage A dual-broker: secondary = public server world (handshakes + vault
# recovery work outside box range and after the camp).
VITE_RELAY_URL_2=wss://relay.web-of-trust.de
VITE_VAULT_URL_2=https://vault.web-of-trust.de
VITE_PROFILE_SERVICE_URL_2=https://profiles.web-of-trust.de

# #238: pin this side-loaded test build to its shipped bundle — never fetch the
# production OTA bundle (which would swap the box build for the prod bundle).
VITE_DISABLE_LIVE_UPDATE=true
