# Spur-B nativer Geräte-Dry-Run — Staging-Backend + D2-Observability AKTIV.
#
# NUR für side-loaded Debug-APK / manuelles `cap run`. Diese Datei darf NIEMALS
# durch die F-Droid-/OTA-Release-Pipeline laufen (siehe docs/testing/spur-b-native-dryrun.md,
# Abschnitt "Deploy-Path-Guard"). VITE_WOT_DEBUG_OBSERVABILITY=1 aktiviert den sensiblen
# D2-Test-Kanal (deviceId/Heads/Keystore-Status) und gehört in KEINEN prod-Build.
#
# Aktivierung ausschliesslich explizit via:  vite build --mode staging-debug

VITE_BASE_PATH=/
VITE_RELAY_URL=wss://relay-staging.web-of-trust.de
VITE_PROFILE_SERVICE_URL=https://profiles-staging.web-of-trust.de
VITE_VAULT_URL=https://vault-staging.web-of-trust.de
VITE_WOT_DEBUG_OBSERVABILITY=1

# #238: pin this side-loaded test build to its shipped bundle — never fetch the
# production OTA bundle (which would shadow our fix and revert to the old wordlist).
VITE_DISABLE_LIVE_UPDATE=true
