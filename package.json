{
  "name": "web-of-trust",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "bench": "turbo bench",
    "dev:demo": "pnpm --filter demo dev",
    "dev:demo:yjs": "VITE_CRDT=yjs pnpm --filter demo dev",
    "dev:landing": "pnpm --filter landing dev",
    "build:core": "pnpm --filter @web_of_trust/core build",
    "agent:review-pr": "node scripts/agent-review-pr.mjs"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "~5.7.2"
  }
}
