{
  "name": "@web_of_trust/relay",
  "version": "0.1.2",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx src/start.ts",
    "prebuild": "pnpm --filter @web_of_trust/core build",
    "build": "tsc",
    "pretest": "pnpm --filter @web_of_trust/core build",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretypecheck": "pnpm --filter @web_of_trust/core build",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@web_of_trust/core": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "~5.7.2",
    "vitest": "^4.1.0"
  }
}
