{
  "name": "@web.of.trust/adapter-automerge",
  "version": "0.1.0",
  "description": "Automerge CRDT adapter for Web of Trust — Rust/WASM-based replication and personal document management",
  "repository": {
    "type": "git",
    "url": "https://github.com/antontranelis/web-of-trust.git",
    "directory": "packages/adapter-automerge"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.3",
    "@automerge/automerge-repo": "^2.5.3",
    "@automerge/automerge-repo-storage-indexeddb": "^2.5.3"
  },
  "peerDependencies": {
    "@web.of.trust/core": "workspace:*"
  },
  "devDependencies": {
    "@web.of.trust/core": "workspace:*",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.5.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.1.0"
  }
}
